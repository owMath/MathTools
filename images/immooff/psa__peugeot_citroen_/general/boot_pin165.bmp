        $(this).attr('data-modal', 'modalRegistrationRequired');
        $(this).after(' <svg class="icon icon--xxs" viewBox="0 0 12 12"><title>Premium content</title><path d="M5,5V3A1,1,0,0,1,7,3V5H9V3A3,3,0,0,0,3,3V5Z"></path><rect x="1" y="6" width="10" height="6" rx="1"></rect></svg>');
    }

    // accessibility
    var name = $(this);
    name.text(name.text().trim().replaceAll(/-/ig, " "));
});
